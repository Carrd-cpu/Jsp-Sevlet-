数据库内容
//创建用户表
CREATE TABLE Users(
  userId int primary key auto_increment,
  userName varchar(50),
  password varchar(50),
  sex char(1),
  email varchar(50),
  role varchar(20)
);
//创建问题表
CREATE TABLE question(
  questionId int primary key auto_increment,
  title varchar(100),
  optionA varchar(50),
  optionB varchar(50),
  optionC varchar(50),
  optionD varchar(50),
  answer char(1)
);
